# === הגדרות המשרד ===
FIRM_NAME=משרד עורכי דין
PORT=4000

# === בסיס נתונים (יוגדר אוטומטית ע"י install.sh) ===
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/lawfirm

# === אבטחה (יוגדר אוטומטית ע"י install.sh) ===
JWT_SECRET=CHANGE_ME

# === n8n אוטומציות ===
N8N_WEBHOOK_BASE=http://n8n:5678/webhook
N8N_WEBHOOK_SECRET=CHANGE_ME
